# ==========================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG (ENVIRONMENT)
# COPY FILE NÀY THÀNH FILE .env ĐỂ SỬ DỤNG
# ==========================================

# 1. Cấu hình Email SMTP (Gửi Email Wishlist)
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password_16_letters"

# 2. Cấu hình Database (Nếu cần sau này)
DB_HOSTNAME="localhost"
DB_USERNAME="root"
DB_PASSWORD=""
DB_NAME="hcmue_pass_sach"

# 3. Cấu hình Google Gemini AI API Key (Dùng cho kiểm duyệt tự động & Trợ lý ảo)
# Đăng ký tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# 4. Cấu hình Pusher Channels (Dùng cho Realtime Chat & Thông báo đơn hàng)
# Đăng ký tại: https://pusher.com
PUSHER_APP_ID="your_pusher_app_id"
PUSHER_APP_KEY="your_pusher_key"
PUSHER_APP_SECRET="your_pusher_secret"
PUSHER_APP_CLUSTER="ap1"
PUSHER_KEY="your_pusher_key"
PUSHER_SECRET="your_pusher_secret"
PUSHER_CLUSTER="ap1"

# 5. Cấu hình PayOS (Cổng thanh toán QR Code tự động)
# Đăng ký tại: https://payos.vn/ → Lấy key từ https://my.payos.vn/
# Nếu để trống hoặc giữ nguyên "your_...", hệ thống sẽ chạy ở chế độ Demo (Mock)
PAYOS_CLIENT_ID="your_client_id"
PAYOS_API_KEY="your_api_key"
PAYOS_CHECKSUM_KEY="your_checksum_key"
