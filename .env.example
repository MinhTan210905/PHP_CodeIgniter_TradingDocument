# ==========================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG (ENVIRONMENT)
# COPY FILE NÀY THÀNH FILE .env ĐỂ SỬ DỤNG
# ==========================================

# 1. Cấu hình Email SMTP (Gửi OTP)
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password_16_letters"

# 2. Cấu hình Database (Nếu cần sau này)
DB_HOSTNAME="localhost"
DB_USERNAME="root"
DB_PASSWORD=""
DB_NAME="hcmue_pass_sach"

# 3. Cấu hình PayOS (Cổng thanh toán QR Code tự động)
# Đăng ký tại: https://payos.vn/ → Lấy key từ https://my.payos.vn/
# Nếu để trống hoặc giữ nguyên "your_...", hệ thống sẽ chạy ở chế độ Demo (Mock)
PAYOS_CLIENT_ID="your_client_id"
PAYOS_API_KEY="your_api_key"
PAYOS_CHECKSUM_KEY="your_checksum_key"
